---
interface Slide {
  title: string;
  image: string;
  meta?: string;
}

interface Props {
  slides: Slide[];
  label?: string;
}

const { slides, label = "Photo highlights" } = Astro.props;
---

<div class="carousel card" data-carousel role="group" aria-label={label}>
  <div class="track" data-track tabindex="0" aria-live="polite">
    {
      slides.map((slide) => (
        <figure class="slide">
          <img
            src={slide.image}
            alt={slide.title}
            width="800"
            height="600"
            loading="lazy"
            decoding="async"
          />
          <figcaption>
            <span class="slide-title">{slide.title}</span>
            {slide.meta && <span class="slide-meta">{slide.meta}</span>}
          </figcaption>
        </figure>
      ))
    }
  </div>

  <div class="controls">
    <button class="arrow" type="button" data-prev aria-label="Previous photo">
      <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="M15 5l-7 7 7 7"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </button>

    <div class="dots" role="tablist" aria-label="Choose photo">
      {
        slides.map((slide, i) => (
          <button
            class="dot"
            type="button"
            data-dot
            aria-label={`Photo ${i + 1}: ${slide.title}`}
            aria-current={i === 0 ? "true" : "false"}
          />
        ))
      }
    </div>

    <button class="arrow" type="button" data-next aria-label="Next photo">
      <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="M9 5l7 7-7 7"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </button>
  </div>
</div>

<style>
  .carousel {
    overflow: hidden;
  }

  .track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    overscroll-behavior-x: contain;
    scrollbar-width: none;
  }

  .track::-webkit-scrollbar {
    display: none;
  }

  .slide {
    position: relative;
    flex: 0 0 100%;
    margin: 0;
    scroll-snap-align: start;
  }

  .slide img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .slide figcaption {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.25rem 0.75rem;
    padding: 0.85rem 1.1rem;
    background: var(--scrim);
    color: #fff;
  }

  .slide-title {
    font-size: 0.95rem;
    font-weight: 600;
  }

  .slide-meta {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.75);
  }

  .controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    border-top: 1px solid var(--line);
    background: var(--surface);
  }

  .arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid var(--line);
    color: var(--ink-2);
    background: var(--surface);
    transition: border-color 0.15s ease, color 0.15s ease,
      background-color 0.15s ease;
  }

  .arrow:hover {
    border-color: var(--accent-line);
    background: var(--accent-tint);
    color: var(--accent-strong);
  }

  .dots {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .dot {
    width: 22px;
    height: 22px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .dot::after {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--line-strong);
    transition: background-color 0.15s ease, transform 0.15s ease;
  }

  .dot:hover::after {
    background: var(--ink-3);
  }

  .dot[aria-current="true"]::after {
    background: var(--accent);
    transform: scale(1.25);
  }
</style>

<script>
  const reduceMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)"
  ).matches;

  document.querySelectorAll<HTMLElement>("[data-carousel]").forEach((root) => {
    const track = root.querySelector<HTMLElement>("[data-track]");
    if (!track) return;

    const slides = Array.from(track.children);
    const dots = Array.from(
      root.querySelectorAll<HTMLButtonElement>("[data-dot]")
    );
    const count = slides.length;

    const current = () =>
      Math.round(track.scrollLeft / Math.max(1, track.clientWidth));

    const goTo = (i: number) => {
      const target = ((i % count) + count) % count; // wrap around
      track.scrollTo({
        left: target * track.clientWidth,
        behavior: reduceMotion ? "auto" : "smooth",
      });
    };

    root
      .querySelector("[data-prev]")
      ?.addEventListener("click", () => goTo(current() - 1));
    root
      .querySelector("[data-next]")
      ?.addEventListener("click", () => goTo(current() + 1));

    dots.forEach((dot, i) => dot.addEventListener("click", () => goTo(i)));

    let raf = 0;
    track.addEventListener(
      "scroll",
      () => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          const i = current();
          dots.forEach((dot, j) =>
            dot.setAttribute("aria-current", j === i ? "true" : "false")
          );
        });
      },
      { passive: true }
    );
  });
</script>
