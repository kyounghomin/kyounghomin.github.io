---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="cols">
      <div class="footer-info">
        <div class="brand-row">
          <svg
            class="brand-mark"
            width="41"
            height="22"
            viewBox="150 110 900 480"
            aria-hidden="true"
          >
            <g fill="#00265f">
              <rect x="150" y="110" width="330" height="100"></rect>
              <rect x="150" y="300" width="330" height="100"></rect>
              <rect x="150" y="490" width="330" height="100"></rect>
              <rect x="540" y="110" width="120" height="100"></rect>
            </g>
            <g fill="#303438">
              <rect x="540" y="250" width="120" height="340"></rect>
              <rect x="720" y="110" width="330" height="100"></rect>
              <rect x="720" y="110" width="100" height="480"></rect>
              <rect x="720" y="490" width="330" height="100"></rect>
            </g>
          </svg>
          <p class="footer-brand">EIC Lab</p>
          <span class="brand-divider" aria-hidden="true"></span>
          <a
            class="social"
            href="https://github.com/EIC-SKKU"
            aria-label="GitHub"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              ></path>
            </svg>
          </a>
          <a class="social" href="https://www.linkedin.com/" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"
              ></path>
            </svg>
          </a>
        </div>
        <div class="details">
          <div class="col">
            <p class="footer-head">Location</p>
            <p class="muted">
              Sungkyunkwan University<br />
              College of Information and Communication Engineering &amp; Semiconductor Systems Engineering<br />
              2066 Seobu-ro, Jangan-gu, Suwon<br />
              Gyeonggi-do 16419, Republic of Korea
            </p>
          </div>

          <div class="col">
            <p class="footer-head">Contact</p>
            <ul class="contact-list">
              <li><a href="mailto:yulhwakim@skku.edu">yulhwakim_at_skku_dot_edu</a></li>
              <li>+82-31-299-4911</li>
              <li>Semiconductor Building 3rd Floor, Room 400306</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="location">
        <p class="footer-head">Location</p>
        <div class="footer-map-shell">
          <iframe
            class="footer-map"
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
            src="https://www.google.com/maps/embed/v1/place?q=place_id:ChIJU_EetclCezURoeyvzVnXfIg&key=AIzaSyAvnmOg8l5fvCOSB853iLIQqMDGNhCM-js"
            title="EIC Lab location on Google Maps"
          ></iframe>
        </div>
      </div>
    </div>

    <div class="bottom">
      <p>© {year} EIC Lab, Sungkyunkwan University. All rights reserved.</p>
      <p>Suwon, Republic of Korea</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: clamp(3rem, 7vw, 5rem);
    border-top: 1px solid var(--line);
    background: var(--surface-2);
  }

  .cols {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(390px, 0.88fr);
    align-items: stretch;
    gap: clamp(3rem, 6vw, 5rem);
    padding-block: clamp(2.25rem, 5vw, 3.25rem);
  }

  .footer-info {
    display: flex;
    min-width: 0;
    flex-direction: column;
  }

  .brand-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }

  .brand-mark {
    flex: none;
  }

  .footer-brand {
    font-size: 1.35rem;
    font-weight: 700;
  }

  .social {
    display: inline-flex;
    margin-top: 2px;
    color: var(--ink-3);
    transition: color 0.15s ease;
  }

  /* same hairline divider as the navbar brand */
  .brand-divider {
    flex: none;
    width: 1px;
    height: 20px;
    background: var(--line);
    margin-inline: 0.5rem;
  }

  .social svg {
    width: 19px;
    height: 19px;
  }

  .social:hover {
    color: var(--accent-strong);
  }

  .details {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(190px, 0.8fr);
    gap: clamp(2rem, 4vw, 3.5rem);
  }

  .footer-head {
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 0.75rem;
  }

  .muted {
    color: var(--ink-2);
    font-size: 0.92rem;
    line-height: 1.7;
    max-width: 38ch;
  }

  .location {
    display: flex;
    min-width: 0;
    flex-direction: column;
  }

  .footer-map-shell {
    width: 100%;
    min-height: 250px;
    flex: 1;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    box-shadow: 0 10px 30px rgb(25 30 40 / 0.06);
  }

  .footer-map {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .contact-list {
    display: grid;
    gap: 0.45rem;
    color: var(--ink-2);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .contact-list a:hover {
    color: var(--accent-strong);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    border-top: 1px solid var(--line);
    padding-block: 1.25rem;
    font-size: 0.85rem;
    color: var(--ink-3);
  }

  @media (max-width: 860px) {
    .cols {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .brand-row {
      margin-bottom: 2rem;
    }

    .footer-map-shell {
      height: clamp(260px, 55vw, 360px);
      flex: none;
    }
  }

  @media (max-width: 560px) {
    .details {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }

    .bottom {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.35rem;
    }
  }
</style>
