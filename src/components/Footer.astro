---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="cols">
      <div class="footer-info">
        <p class="footer-brand">EIC Lab</p>
        <div class="details">
          <div class="col">
            <p class="footer-head">University</p>
            <p class="muted">
              Sungkyunkwan University<br />
              College of Information &amp; Communication Engineering<br />
              2066 Seobu-ro, Jangan-gu, Suwon<br />
              Gyeonggi-do 16419, Republic of Korea
            </p>
          </div>

          <div class="col">
            <p class="footer-head">Contact</p>
            <ul class="contact-list">
              <li><a href="mailto:eiclab@skku.edu">eiclab@skku.edu</a></li>
              <li>+82-31-290-0000</li>
              <li>Engineering Building 2, Room 27314</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="location">
        <p class="footer-head">Location</p>
        <div class="footer-map-shell">
          <iframe
            class="footer-map"
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
            src="https://www.google.com/maps/embed/v1/place?q=place_id:ChIJU_EetclCezURoeyvzVnXfIg&key=AIzaSyAvnmOg8l5fvCOSB853iLIQqMDGNhCM-js"
            title="EIC Lab location on Google Maps"
          ></iframe>
        </div>
      </div>
    </div>

    <div class="bottom">
      <p>© {year} EIC Lab, Sungkyunkwan University. All rights reserved.</p>
      <p>Suwon, Republic of Korea</p>
    </div>
  </div>
</footer>

<style>
  /* distinct gray panel so the footer reads as a separate zone */
  .site-footer {
    margin-top: clamp(3rem, 7vw, 5rem);
    border-top: 1px solid var(--line);
    background: var(--surface-2);
  }

  .cols {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(390px, 0.88fr);
    align-items: stretch;
    gap: clamp(3rem, 6vw, 5rem);
    padding-block: clamp(2.25rem, 5vw, 3.25rem);
  }

  .footer-info {
    display: flex;
    min-width: 0;
    flex-direction: column;
  }

  .footer-brand {
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }

  .details {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(190px, 0.8fr);
    gap: clamp(2rem, 4vw, 3.5rem);
  }

  .footer-head {
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 0.75rem;
  }

  .muted {
    color: var(--ink-2);
    font-size: 0.92rem;
    line-height: 1.7;
    max-width: 38ch;
  }

  .location {
    display: flex;
    min-width: 0;
    flex-direction: column;
  }

  .footer-map-shell {
    width: 100%;
    min-height: 250px;
    flex: 1;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    box-shadow: 0 10px 30px rgb(25 30 40 / 0.06);
  }

  .footer-map {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .contact-list {
    display: grid;
    gap: 0.45rem;
    color: var(--ink-2);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .contact-list a:hover {
    color: var(--accent-strong);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    border-top: 1px solid var(--line);
    padding-block: 1.25rem;
    font-size: 0.85rem;
    color: var(--ink-3);
  }

  @media (max-width: 860px) {
    .cols {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .footer-brand {
      margin-bottom: 2rem;
    }

    .footer-map-shell {
      height: clamp(260px, 55vw, 360px);
      flex: none;
    }
  }

  @media (max-width: 560px) {
    .details {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }

    .bottom {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.35rem;
    }
  }
</style>
