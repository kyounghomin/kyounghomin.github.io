---
interface Props {
  kicker: string;
  title: string;
}

const { kicker, title } = Astro.props;
---

<div class="page-header">
  <div class="container">
    <p class="kicker">{kicker}</p>
    <h1>{title}</h1>
  </div>
</div>

<style>
  .page-header {
    border-bottom: 1px solid var(--line);
    background: var(--surface);
    padding-block: clamp(2rem, 5vw, 3rem);
  }

  h1 {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    margin-top: 0.7rem;
  }
</style>
