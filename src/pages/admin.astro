---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
---

<Base title="Content Studio" noindex>
  <PageHeader kicker="Admin" title="Content Studio" />

  <div class="container section">
    <p class="intro">
      Manage news, gallery images, members, publications, and research content
      with an authorized GitHub account.
    </p>

    <div class="actions">
      <a
        class="btn btn-primary"
        href="https://app.pagescms.org/"
        target="_blank"
        rel="noopener noreferrer"
      >
        Open content manager
      </a>
      <a
        class="btn btn-ghost"
        href="https://github.com/kyounghomin/kyounghomin.github.io/actions/workflows/deploy.yml"
        target="_blank"
        rel="noopener noreferrer"
      >
        Deployment status
      </a>
    </div>

    <dl class="admin-meta card">
      <div>
        <dt>Repository</dt>
        <dd>kyounghomin/kyounghomin.github.io</dd>
      </div>
      <div>
        <dt>Branch</dt>
        <dd>main</dd>
      </div>
      <div>
        <dt>Publishing</dt>
        <dd>Automatic after save</dd>
      </div>
    </dl>
  </div>
</Base>

<style>
  .intro {
    max-width: 58ch;
    color: var(--ink-2);
    font-size: 0.97rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .admin-meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
    padding: 1.4rem 1.5rem;
  }

  .admin-meta dt {
    color: var(--ink-3);
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .admin-meta dd {
    margin: 0.35rem 0 0;
    overflow-wrap: anywhere;
    color: var(--ink-2);
    font-size: 0.88rem;
  }

  @media (max-width: 620px) {
    .actions {
      display: grid;
    }

    .admin-meta {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>
