---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";

const details = [
  {
    label: "Email",
    value: "eiclab@skku.edu",
    href: "mailto:eiclab@skku.edu",
  },
  {
    label: "Phone",
    value: "+82-31-290-0000",
  },
  {
    label: "Office",
    value: "Engineering Building 2, Room 27314",
  },
  {
    label: "Address",
    value:
      "Sungkyunkwan University, 2066 Seobu-ro, Jangan-gu, Suwon, Gyeonggi-do 16419, Republic of Korea",
  },
];
---

<Base title="Contact">
  <PageHeader
    kicker="Contact"
    title="Get in Touch"
    lede="Questions about our research, collaborations, or joining the lab — we would love to hear from you."
  />

  <div class="container section">
    <div class="grid">
      <section class="info card" aria-label="Contact details">
        <dl>
          {
            details.map((item) => (
              <div class="row">
                <dt>{item.label}</dt>
                <dd>
                  {item.href ? (
                    <a href={item.href}>{item.value}</a>
                  ) : (
                    item.value
                  )}
                </dd>
              </div>
            ))
          }
        </dl>
      </section>

      <aside class="join card">
        <p class="kicker">Prospective students</p>
        <h2>Join EIC Lab</h2>
        <p>
          We are recruiting Ph.D., M.S., and undergraduate researchers who are
          excited about efficient AI, chip design, and computer systems. Send
          us a short introduction along with your CV and transcript.
        </p>
        <a class="btn btn-primary" href="mailto:eiclab@skku.edu?subject=Joining%20EIC%20Lab"
          >Email the lab</a
        >
      </aside>
    </div>
  </div>
</Base>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 1.25rem;
    align-items: start;
  }

  .info {
    padding: clamp(1.5rem, 3vw, 2rem);
  }

  dl {
    margin: 0;
    display: grid;
  }

  .row {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 1rem;
    padding-block: 0.95rem;
  }

  .row + .row {
    border-top: 1px solid var(--line);
  }

  .row:first-child {
    padding-top: 0;
  }

  .row:last-child {
    padding-bottom: 0;
  }

  dt {
    font-size: 0.78rem;
    font-weight: 650;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
    padding-top: 0.15rem;
  }

  dd {
    margin: 0;
    font-size: 0.95rem;
    color: var(--ink);
  }

  dd a {
    color: var(--accent-strong);
  }

  dd a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .join {
    padding: clamp(1.5rem, 3vw, 2rem);
    background: var(--accent-tint);
    border-color: var(--accent-line);
  }

  .join h2 {
    font-size: 1.5rem;
    margin-top: 0.7rem;
  }

  .join p:not(.kicker) {
    margin-top: 0.75rem;
    color: var(--ink-2);
    font-size: 0.94rem;
  }

  .join .btn {
    margin-top: 1.25rem;
  }

  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .row {
      grid-template-columns: 1fr;
      gap: 0.2rem;
    }
  }
</style>
