---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";

const items = (await getCollection("gallery")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categories = [...new Set(items.map((item) => item.data.category))];

const fmt = (date: Date) =>
  date.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });
---

<Base title="Gallery">
  <PageHeader
    kicker="Gallery"
    title="Life at EIC Lab"
    lede="Conferences, workshops, group photos, and everything in between. Featured photos also appear in the carousel on the home page."
  />

  <div class="container section">
    <div class="filters" role="group" aria-label="Filter photos by category">
      <button class="filter chip" type="button" data-filter="all" aria-pressed="true">
        All
      </button>
      {
        categories.map((category) => (
          <button
            class="filter chip"
            type="button"
            data-filter={category}
            aria-pressed="false"
          >
            {category}
          </button>
        ))
      }
    </div>

    <div class="gallery-grid" data-gallery>
      {
        items.map((item) => (
          <figure class="item card" data-category={item.data.category}>
            <img
              src={item.data.image}
              alt={item.data.title}
              width="800"
              height="600"
              loading="lazy"
              decoding="async"
            />
            <figcaption>
              <span class="title">{item.data.title}</span>
              <span class="meta">
                <time datetime={item.data.date.toISOString().slice(0, 10)}>
                  {fmt(item.data.date)}
                </time>
                · {item.data.category}
                {item.data.featured && (
                  <span class="featured">★ Featured</span>
                )}
              </span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</Base>

<style>
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
  }

  .filter {
    cursor: pointer;
    min-height: 40px;
    padding-inline: 1rem;
  }

  .filter:hover {
    border-color: var(--accent-line);
    color: var(--accent-strong);
  }

  .filter[aria-pressed="true"] {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.15rem;
  }

  .item {
    margin: 0;
    overflow: hidden;
    transition: border-color 0.15s ease;
  }

  .item:hover {
    border-color: var(--line-strong);
  }

  .item img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .item[hidden] {
    display: none;
  }

  figcaption {
    padding: 0.85rem 1rem 1rem;
  }

  .title {
    display: block;
    font-size: 0.95rem;
    font-weight: 620;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.3rem;
    font-size: 0.8rem;
    color: var(--ink-3);
  }

  .featured {
    color: var(--accent-strong);
    background: var(--accent-tint);
    border: 1px solid var(--accent-line);
    border-radius: 999px;
    padding: 0.05rem 0.5rem;
    font-size: 0.72rem;
    font-weight: 600;
  }

  @media (max-width: 980px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 520px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>("[data-filter]");
  const items = document.querySelectorAll<HTMLElement>("[data-gallery] [data-category]");

  filters.forEach((button) => {
    button.addEventListener("click", () => {
      const value = button.dataset.filter;

      filters.forEach((other) =>
        other.setAttribute("aria-pressed", other === button ? "true" : "false")
      );

      items.forEach((item) => {
        const show = value === "all" || item.dataset.category === value;
        item.toggleAttribute("hidden", !show);
      });
    });
  });
</script>
