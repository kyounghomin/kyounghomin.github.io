---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Carousel from "../components/Carousel.astro";

const news = (await getCollection("news"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const featured = (await getCollection("gallery", ({ data }) => data.featured))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (date: Date) =>
  date.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });

const slides = featured.map((item) => ({
  title: item.data.title,
  image: item.data.image,
  meta: fmt(item.data.date),
}));
---

<Base>
  <section class="container home">
    <!-- Quiet one-line identity: lab name left, affiliation right -->
    <header class="identity">
      <h1>Efficient &amp; Intelligent Computing Lab</h1>
      <p class="affiliation">
        <img
          class="skku-mark"
          src="/skku_logo_transparent.png"
          alt=""
          width="285"
          height="285"
        />
        <span class="identity-sub">Sungkyunkwan University</span>
      </p>
    </header>

    <div class="main-grid">
      <section class="news-col" aria-labelledby="news-heading">
        <div class="col-head">
          <h2 id="news-heading">News &amp; Updates</h2>
          <a class="head-link" href="/news/">All news →</a>
        </div>
        <ul class="news-list">
          {
            news.map((item) => (
              <li class="news-item">
                <time
                  class="mono"
                  datetime={item.data.date.toISOString().slice(0, 10)}
                >
                  {fmt(item.data.date)}
                </time>
                <div>
                  <h3>{item.data.title}</h3>
                  <p>{item.data.description}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </section>

      <div class="carousel-col">
        <Carousel slides={slides} label="Featured photos from the gallery" />
      </div>
    </div>
  </section>
</Base>

<style>
  .home {
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  /* ---- identity line ---- */
  .identity {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.7rem 1.5rem;
    padding-bottom: clamp(2rem, 4vw, 3rem);
    margin-bottom: clamp(2rem, 4vw, 3rem);
    border-bottom: 1px solid var(--line);
  }

  .identity h1 {
    font-size: clamp(1.6rem, 3.2vw, 2.1rem);
    font-weight: 650;
  }

  /* emblem + university name share one center line */
  .affiliation {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    flex: none;
  }

  .skku-mark {
    width: clamp(2.1rem, 3.2vw, 2.6rem);
    aspect-ratio: 1;
    flex: none;
    object-fit: contain;
  }

  .identity-sub {
    font-family: var(--mono);
    font-size: 0.78rem;
    font-weight: 650;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-2);
  }

  /* ---- news + carousel ---- */
  .main-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: start;
  }

  .col-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  #news-heading {
    font-size: clamp(1.35rem, 2.4vw, 1.65rem);
    font-weight: 660;
    line-height: 1.2;
  }

  .head-link {
    font-size: 0.88rem;
    font-weight: 550;
    color: var(--ink-2);
    white-space: nowrap;
  }

  .head-link:hover {
    color: var(--accent-strong);
  }

  .news-list {
    display: grid;
  }

  .news-item {
    display: grid;
    grid-template-columns: 108px 1fr;
    gap: 1rem;
    padding-block: 1.4rem;
    border-top: 1px solid var(--line);
  }

  .news-item time {
    font-size: 0.78rem;
    color: var(--ink-3);
    padding-top: 0.25rem;
  }

  .news-item h3 {
    font-size: 1.05rem;
    font-weight: 620;
    letter-spacing: 0;
    line-height: 1.4;
  }

  .news-item p {
    margin-top: 0.3rem;
    font-size: 0.9rem;
    color: var(--ink-2);
  }

  @media (max-width: 860px) {
    .main-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .identity {
      align-items: flex-start;
      flex-direction: column;
    }

    .news-item {
      grid-template-columns: 1fr;
      gap: 0.2rem;
    }
  }
</style>
