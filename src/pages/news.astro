---
import { getCollection, render } from "astro:content";
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";

const news = (await getCollection("news")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const posts = await Promise.all(
  news.map(async (item) => ({
    item,
    Content: (await render(item)).Content,
    hasBody: (item.body ?? "").trim().length > 0,
  }))
);

const fmt = (date: Date) =>
  date.toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
---

<Base title="News">
  <PageHeader kicker="EIC Lab" title="News & Updates" />

  <div class="container section">
    <div class="post-grid">
      {
        posts.map(({ item, Content, hasBody }) => (
          <article class="post card" data-post>
            <button
              class="post-open"
              type="button"
              data-open
              aria-haspopup="dialog"
            >
              <time
                class="mono"
                datetime={item.data.date.toISOString().slice(0, 10)}
              >
                {fmt(item.data.date)}
              </time>
              <h2>{item.data.title}</h2>
              <p class="post-desc">{item.data.description}</p>
              <span class="more" aria-hidden="true">
                Read more →
              </span>
            </button>

            <dialog class="post-dialog" aria-label={item.data.title}>
              <div class="dialog-body">
                <button
                  class="close"
                  type="button"
                  data-close
                  aria-label="Close"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      d="M6 6l12 12M18 6L6 18"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                    />
                  </svg>
                </button>
                <time
                  class="mono"
                  datetime={item.data.date.toISOString().slice(0, 10)}
                >
                  {fmt(item.data.date)}
                </time>
                <h2>{item.data.title}</h2>
                <div class="dialog-content">
                  {hasBody ? <Content /> : <p>{item.data.description}</p>}
                </div>
              </div>
            </dialog>
          </article>
        ))
      }
    </div>
  </div>
</Base>

<style>
  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.15rem;
  }

  .post {
    transition: border-color 0.15s ease;
  }

  .post:hover {
    border-color: var(--accent-line);
  }

  .post-open {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
    height: 100%;
    padding: 1.35rem 1.4rem 1.3rem;
    text-align: left;
    cursor: pointer;
  }

  .post time {
    font-size: 0.75rem;
    color: var(--ink-3);
  }

  .post h2 {
    margin-top: 0.55rem;
    font-size: 1.12rem;
    font-weight: 640;
    line-height: 1.35;
  }

  .post:hover h2 {
    color: var(--accent-strong);
  }

  .post-desc {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--ink-2);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
  }

  .more {
    margin-top: auto;
    padding-top: 0.9rem;
    font-size: 0.82rem;
    font-weight: 550;
    color: var(--accent);
  }

  /* ---- dialog ---- */
  .post-dialog {
    border: none;
    padding: 0;
    border-radius: var(--radius);
    max-width: min(640px, calc(100vw - 2rem));
    width: 100%;
    box-shadow: 0 24px 60px rgb(15 20 30 / 0.25);
  }

  .post-dialog::backdrop {
    background: rgba(20, 24, 31, 0.55);
  }

  .dialog-body {
    position: relative;
    padding: clamp(1.5rem, 4vw, 2.25rem);
  }

  .dialog-body time {
    font-size: 0.78rem;
    color: var(--ink-3);
  }

  .dialog-body h2 {
    margin-top: 0.5rem;
    padding-right: 2.5rem;
    font-size: 1.45rem;
  }

  .dialog-content {
    margin-top: 1rem;
    font-size: 0.97rem;
    line-height: 1.65;
    color: var(--ink-2);
  }

  .dialog-content :global(p + p) {
    margin-top: 0.7rem;
  }

  .close {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 999px;
    color: var(--ink-2);
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .close:hover {
    background: var(--surface-2);
    color: var(--ink);
  }

  @media (max-width: 960px) {
    .post-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-post]").forEach((post) => {
    const dialog = post.querySelector("dialog");
    if (!dialog) return;

    post
      .querySelector("[data-open]")
      ?.addEventListener("click", () => dialog.showModal());
    dialog
      .querySelector("[data-close]")
      ?.addEventListener("click", () => dialog.close());
    // click on the backdrop closes (the padded body swallows inner clicks)
    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) dialog.close();
    });
  });
</script>
