---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import MemberDialog from "../../components/MemberDialog.astro";
import { ROLE_LABELS } from "../../lib/roles";
import {
  buildMemberMaps,
  resolveAuthorReferences,
} from "../../lib/authors";

export async function getStaticPaths() {
  const posts = await getCollection("notes");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allMembers = await getCollection("members");
const { membersByName, membersById, memberDisambiguation } = buildMemberMaps(allMembers);
const authors = resolveAuthorReferences(
  post.data.authors,
  membersByName,
  membersById
);

const popupMembers = [...new Set(
  authors
    .map((author) => author.member)
    .filter((member) => member && member.role !== "professor")
    .map((member) => member!.id)
)]
  .map((id) => membersById.get(id))
  .filter((m): m is NonNullable<typeof m> => m !== undefined);

const fmt = (date: Date) =>
  date.toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
---

<Base title={post.data.title} description={post.data.summary}>
  <article class="container post-page">
    <a class="back" href="/notes/">← All notes</a>

    <header class="post-header">
      {post.data.category && (
        <p class="kicker">{post.data.category}</p>
      )}
      <h1>{post.data.title}</h1>
      <p class="meta">
        <time datetime={post.data.date.toISOString().slice(0, 10)}>
          {fmt(post.data.date)}
        </time>
      </p>
      {authors.length > 0 && (
        <div class="byline" aria-label={`Authors: ${authors.map((author) => author.name).join(", ")}`}>
          <span class="by-label">By</span>
          <div class="by-authors">
            {authors.map((author) => {
              const member = author.member;
              const contents = (
                <>
                  <img
                    src={member?.image ?? "/images/members/placeholder.svg"}
                    alt=""
                    width="28"
                    height="28"
                    loading="eager"
                    decoding="async"
                  />
                  <span>
                    {author.name}
                    {member && memberDisambiguation.has(member.id) && (
                      <small>
                        {" · "}{ROLE_LABELS[member.role] ?? member.role}
                        {memberDisambiguation.get(member.id)?.sameRoleOrdinal &&
                          ` #${memberDisambiguation.get(member.id)?.sameRoleOrdinal}`}
                      </small>
                    )}
                  </span>
                </>
              );
              if (!member) return <span class="author-person">{contents}</span>;
              if (member.role === "professor") {
                return (
                  <a class="author-person" href={`/members/#member-${member.id}`}>
                    {contents}
                  </a>
                );
              }
              return (
                <button
                  class="author-person"
                  type="button"
                  data-open
                  aria-haspopup="dialog"
                  aria-controls={`member-dialog-${member.id}`}
                >
                  {contents}
                </button>
              );
            })}
          </div>
        </div>
      )}
    </header>

    {post.data.coverImage && (
      <img
        class="cover"
        src={post.data.coverImage}
        alt=""
        width="1200"
        height="675"
        loading="eager"
        decoding="async"
      />
    )}

    <div class="prose">
      <Content />
    </div>
  </article>

  {
    popupMembers.map((m) => (
      <MemberDialog
        dialogId={`member-dialog-${m.id}`}
        name={m.data.name}
        position={ROLE_LABELS[m.data.role] ?? m.data.role}
        track={m.data.track}
        major={m.data.major}
        image={m.data.image}
        interests={m.data.interests}
        currentResearch={m.data.currentResearch}
        publications={m.data.publications}
        email={m.data.email}
        links={m.data.links}
      />
    ))
  }
</Base>

<style>
  .post-page {
    padding-block: clamp(2.5rem, 5vw, 4rem);
    max-width: 760px;
  }

  .back {
    display: inline-block;
    font-size: 0.88rem;
    font-weight: 550;
    color: var(--ink-2);
  }

  .back:hover {
    color: var(--accent-strong);
  }

  .post-header {
    margin-top: clamp(1.5rem, 3vw, 2rem);
  }

  .post-header h1 {
    margin-top: 0.5rem;
    font-size: clamp(1.7rem, 4vw, 2.3rem);
    line-height: 1.25;
  }

  .meta {
    margin-top: 0.75rem;
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--ink-3);
  }

  .byline {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 0.9rem;
    color: var(--ink-3);
    font-size: 0.82rem;
  }

  .by-label {
    flex: none;
    font-family: var(--mono);
  }

  .by-authors {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem;
  }

  .author-person {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 34px;
    padding: 0.18rem 0.55rem 0.18rem 0.2rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface);
    color: var(--ink-2);
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1;
  }

  button.author-person:hover,
  a.author-person:hover {
    border-color: var(--accent-line);
    background: var(--accent-tint);
    color: var(--accent-strong);
  }

  .author-person img {
    width: 28px;
    height: 28px;
    flex: none;
    border-radius: 50%;
    object-fit: cover;
    background: var(--surface-2);
  }

  .author-person small {
    color: var(--ink-3);
    font-size: 0.68rem;
    font-weight: 500;
  }

  .cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    margin-top: clamp(1.75rem, 3vw, 2.5rem);
  }

  /* ---- rendered markdown body ---- */
  .prose {
    margin-top: clamp(2rem, 4vw, 2.75rem);
    font-size: 1.02rem;
    line-height: 1.75;
    color: var(--ink-2);
  }

  .prose :global(p + p),
  .prose :global(* + p),
  .prose :global(p + *) {
    margin-top: 1.15rem;
  }

  .prose :global(h2) {
    margin-top: 2.25rem;
    font-size: 1.35rem;
    font-weight: 660;
    color: var(--ink);
  }

  .prose :global(h3) {
    margin-top: 1.75rem;
    font-size: 1.15rem;
    font-weight: 640;
    color: var(--ink);
  }

  .prose :global(img) {
    display: block;
    width: 100%;
    margin-block: 1.75rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(a:hover) {
    color: var(--accent-strong);
  }

  .prose :global(blockquote) {
    margin-block: 1.5rem;
    padding-left: 1.1rem;
    border-left: 3px solid var(--accent-line);
    color: var(--ink-2);
    font-style: italic;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.4rem;
  }

  .prose :global(ul) {
    list-style: disc;
  }

  .prose :global(ol) {
    list-style: decimal;
  }

  .prose :global(li + li) {
    margin-top: 0.4rem;
  }

  .prose :global(code) {
    font-family: var(--mono);
    font-size: 0.9em;
    background: var(--surface-2);
    border-radius: 4px;
    padding: 0.1em 0.35em;
  }

  .prose :global(pre) {
    max-width: 100%;
    overflow-x: auto;
    margin-block: 1.5rem;
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--surface-2);
  }

  .prose :global(pre code) {
    padding: 0;
    background: transparent;
  }
</style>
