---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import MemberDialog from "../../components/MemberDialog.astro";
import { ROLE_LABELS } from "../../lib/roles";
import {
  buildMemberMaps,
  formatNameList,
  isAuthorSeparator,
  normalizeAuthorName,
} from "../../lib/authors";

export async function getStaticPaths() {
  const posts = await getCollection("notes");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allMembers = await getCollection("members");
const { membersByName, membersBySlug } = buildMemberMaps(allMembers);

const bylineParts = formatNameList(post.data.authors);

const popupMembers = bylineParts
  .filter((part) => !isAuthorSeparator(part))
  .map((name) => membersByName.get(normalizeAuthorName(name)))
  .filter((m): m is NonNullable<typeof m> => m !== undefined && m.role !== "professor")
  .map((m) => membersBySlug.get(m.slug))
  .filter((m): m is NonNullable<typeof m> => m !== undefined);

const fmt = (date: Date) =>
  date.toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
---

<Base title={post.data.title} description={post.data.summary}>
  <article class="container post-page">
    <a class="back" href="/notes/">← All notes</a>

    <header class="post-header">
      {post.data.category && (
        <p class="kicker">{post.data.category}</p>
      )}
      <h1>{post.data.title}</h1>
      <p class="meta">
        <time datetime={post.data.date.toISOString().slice(0, 10)}>
          {fmt(post.data.date)}
        </time>
        {bylineParts.length > 0 && (
          <span class="byline">
            {" "}
            · By{" "}
            {bylineParts.map((part) => {
              const m = membersByName.get(normalizeAuthorName(part));
              if (!m) return part;
              return m.role === "professor" ? (
                <a class="author-name" href={`/members/#member-${m.slug}`}>
                  {part}
                </a>
              ) : (
                <button
                  class="author-name author-name-btn"
                  type="button"
                  data-open
                  aria-haspopup="dialog"
                  aria-controls={`member-dialog-${m.slug}`}
                >
                  {part}
                </button>
              );
            })}
          </span>
        )}
      </p>
    </header>

    {post.data.coverImage && (
      <img
        class="cover"
        src={post.data.coverImage}
        alt=""
        width="1200"
        height="675"
        loading="eager"
        decoding="async"
      />
    )}

    <div class="prose">
      <Content />
    </div>
  </article>

  {
    popupMembers.map((m) => (
      <MemberDialog
        dialogId={`member-dialog-${membersByName.get(normalizeAuthorName(m.data.name))?.slug}`}
        name={m.data.name}
        position={ROLE_LABELS[m.data.role] ?? m.data.role}
        track={m.data.track}
        major={m.data.major}
        image={m.data.image}
        interests={m.data.interests}
        currentResearch={m.data.currentResearch}
        publications={m.data.publications}
        email={m.data.email}
        links={m.data.links}
      />
    ))
  }
</Base>

<style>
  .post-page {
    padding-block: clamp(2.5rem, 5vw, 4rem);
    max-width: 760px;
  }

  .back {
    display: inline-block;
    font-size: 0.88rem;
    font-weight: 550;
    color: var(--ink-2);
  }

  .back:hover {
    color: var(--accent-strong);
  }

  .post-header {
    margin-top: clamp(1.5rem, 3vw, 2rem);
  }

  .post-header h1 {
    margin-top: 0.5rem;
    font-size: clamp(1.7rem, 4vw, 2.3rem);
    line-height: 1.25;
  }

  .meta {
    margin-top: 0.75rem;
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--ink-3);
  }

  .byline {
    font-family: var(--sans);
  }

  .author-name {
    font-weight: 640;
    color: var(--ink-2);
  }

  .author-name-btn {
    font: inherit;
    letter-spacing: inherit;
    border: none;
    background: none;
    padding: 0;
    cursor: pointer;
    font-weight: 640;
  }

  .author-name:hover {
    color: var(--accent-strong);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    margin-top: clamp(1.75rem, 3vw, 2.5rem);
  }

  /* ---- rendered markdown body ---- */
  .prose {
    margin-top: clamp(2rem, 4vw, 2.75rem);
    font-size: 1.02rem;
    line-height: 1.75;
    color: var(--ink-2);
  }

  .prose :global(p + p),
  .prose :global(* + p),
  .prose :global(p + *) {
    margin-top: 1.15rem;
  }

  .prose :global(h2) {
    margin-top: 2.25rem;
    font-size: 1.35rem;
    font-weight: 660;
    color: var(--ink);
  }

  .prose :global(h3) {
    margin-top: 1.75rem;
    font-size: 1.15rem;
    font-weight: 640;
    color: var(--ink);
  }

  .prose :global(img) {
    display: block;
    width: 100%;
    margin-block: 1.75rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(a:hover) {
    color: var(--accent-strong);
  }

  .prose :global(blockquote) {
    margin-block: 1.5rem;
    padding-left: 1.1rem;
    border-left: 3px solid var(--accent-line);
    color: var(--ink-2);
    font-style: italic;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.4rem;
  }

  .prose :global(li + li) {
    margin-top: 0.4rem;
  }

  .prose :global(code) {
    font-family: var(--mono);
    font-size: 0.9em;
    background: var(--surface-2);
    border-radius: 4px;
    padding: 0.1em 0.35em;
  }
</style>
