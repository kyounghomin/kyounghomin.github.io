---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";

const pubs = await getCollection("publications");

const preprints = pubs
  .filter((p) => p.data.preprint)
  .sort((a, b) => b.data.year - a.data.year || a.data.order - b.data.order);

const published = pubs.filter((p) => !p.data.preprint);
const years = [...new Set(published.map((p) => p.data.year))].sort(
  (a, b) => b - a
);
const byYear = (year: number) =>
  published
    .filter((p) => p.data.year === year)
    .sort((a, b) => a.data.order - b.data.order);

const linkLabels: Record<string, string> = {
  paper: "paper",
  code: "code",
  project: "project",
  doi: "doi",
};

const groups = [
  ...(preprints.length ? [{ label: "Pre-Print", items: preprints }] : []),
  ...years.map((year) => ({ label: String(year), items: byYear(year) })),
];
---

<Base title="Publications">
  <PageHeader kicker="Publications" title="Publications" />

  <div class="container section">
    {
      groups.map((group) => (
        <section
          class="year-group"
          aria-labelledby={`group-${group.label.toLowerCase()}`}
        >
          <h2 id={`group-${group.label.toLowerCase()}`} class="year mono">
            {group.label}
          </h2>
          <ul class="pub-list">
            {group.items.map((pub) => (
              <li class="pub">
                <p class="ref">
                  <span class="authors">{pub.data.authors}.</span>{" "}
                  <span class="title">“{pub.data.title}.”</span>{" "}
                  <span class="venue">
                    {pub.data.venue}, {pub.data.year}.
                  </span>
                  {pub.data.venueShort && (
                    <span class="venue-tag mono">{pub.data.venueShort}</span>
                  )}
                </p>
                {Object.values(pub.data.links).some(Boolean) && (
                  <p class="pub-links mono">
                    {Object.entries(pub.data.links)
                      .filter(([, href]) => href)
                      .map(([key, href]) => (
                        <a href={href}>[{linkLabels[key] ?? key}]</a>
                      ))}
                  </p>
                )}
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</Base>

<style>
  .year-group {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 1rem 2rem;
    align-items: start;
  }

  .year-group + .year-group {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }

  .year {
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1.4;
  }

  .pub-list {
    display: grid;
    gap: 1.1rem;
  }

  .pub .ref {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--ink-2);
  }

  .authors {
    color: var(--ink-2);
  }

  .title {
    font-weight: 620;
    color: var(--ink);
  }

  .venue-tag {
    display: inline-block;
    margin-left: 0.5rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--accent-strong);
    background: var(--accent-tint);
    border: 1px solid var(--accent-line);
    border-radius: 4px;
    padding: 0.06rem 0.4rem;
    white-space: nowrap;
    vertical-align: 0.08em;
  }

  .pub-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 0.25rem;
    font-size: 0.78rem;
  }

  .pub-links a {
    color: var(--accent-strong);
  }

  .pub-links a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 700px) {
    .year-group {
      grid-template-columns: 1fr;
      gap: 0.9rem;
    }
  }
</style>
