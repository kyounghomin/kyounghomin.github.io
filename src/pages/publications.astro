---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";

const pubs = await getCollection("publications");

/* preprints are pending publication — they live in a dedicated section on
   top of the page instead of inside the year groups */
const preprints = pubs
  .filter((p) => p.data.preprint)
  .sort((a, b) => b.data.year - a.data.year || a.data.order - b.data.order);

const published = pubs.filter((p) => !p.data.preprint);

const years = [...new Set(published.map((p) => p.data.year))].sort(
  (a, b) => b - a
);

// ponytail: type derived from venue text; add a schema field if it ever guesses wrong
const typeOf = (pub: CollectionEntry<"publications">) =>
  /journal|transactions|magazine/i.test(pub.data.venue)
    ? "Journal"
    : "Conference";

const sections = ["Conference", "Journal"];

const groupsFor = (year: number) => {
  const inYear = published.filter((p) => p.data.year === year);
  return sections
    .map((label) => ({
      label,
      items: inYear
        .filter((p) => typeOf(p) === label)
        .sort((a, b) => a.data.order - b.data.order),
    }))
    .filter((section) => section.items.length > 0);
};

const linkLabels: Record<string, string> = {
  paper: "Paper",
  code: "Code",
  project: "Project page",
  doi: "DOI",
};
---

<Base title="Publications">
  <PageHeader kicker="Publications" title="Publications" />

  <div class="container section">
    {
      preprints.length > 0 && (
        <section class="year-group" aria-labelledby="preprints">
          <h2 id="preprints" class="year mono">
            Preprints
          </h2>
          <div class="year-body">
            <ul class="pub-list">
              {preprints.map((pub) => (
                <li class="pub">
                  <p class="ref">
                    <span class="authors">{pub.data.authors}.</span>{" "}
                    <span class="title">“{pub.data.title}.”</span>{" "}
                    <span class="venue">
                      {pub.data.venue}, {pub.data.year}.
                    </span>
                    {pub.data.venueShort && (
                      <span class="venue-tag mono arxiv">
                        {pub.data.venueShort}
                      </span>
                    )}
                  </p>
                  {Object.values(pub.data.links).some(Boolean) && (
                    <div class="pub-links">
                      {Object.entries(pub.data.links)
                        .filter(([, href]) => href)
                        .map(([key, href]) => (
                          <a class="chip" href={href}>
                            {linkLabels[key] ?? key}
                          </a>
                        ))}
                    </div>
                  )}
                </li>
              ))}
            </ul>
          </div>
        </section>
      )
    }
    {
      years.map((year) => (
        <section class="year-group" aria-labelledby={`year-${year}`}>
          <h2 id={`year-${year}`} class="year mono">
            {year}
          </h2>
          <div class="year-body">
            {groupsFor(year).map((section) => (
              <section class="type-group" aria-label={`${section.label}, ${year}`}>
                <h3 class="type-label kicker">{section.label}</h3>
                <ul class="pub-list">
                  {section.items.map((pub) => (
                    <li class="pub">
                      <p class="ref">
                        <span class="authors">{pub.data.authors}.</span>{" "}
                        <span class="title">“{pub.data.title}.”</span>{" "}
                        <span class="venue">
                          {pub.data.venue}, {pub.data.year}.
                        </span>
                        {pub.data.venueShort && (
                          <span
                            class:list={[
                              "venue-tag",
                              "mono",
                              { arxiv: pub.data.preprint },
                            ]}
                          >
                            {pub.data.venueShort}
                          </span>
                        )}
                      </p>
                      {Object.values(pub.data.links).some(Boolean) && (
                        <div class="pub-links">
                          {Object.entries(pub.data.links)
                            .filter(([, href]) => href)
                            .map(([key, href]) => (
                              <a class="chip" href={href}>
                                {linkLabels[key] ?? key}
                              </a>
                            ))}
                        </div>
                      )}
                    </li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</Base>

<style>
  .year-group {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 1rem 2rem;
    align-items: start;
  }

  .year-group + .year-group {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }

  .year {
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1.4;
  }

  .year-body {
    display: grid;
    gap: 1.6rem;
  }

  .type-label {
    margin-bottom: 0.75rem;
  }

  .pub-list {
    display: grid;
    gap: 1.35rem;
  }

  .pub .ref {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--ink-2);
  }

  .authors {
    color: var(--ink-2);
  }

  .title {
    font-weight: 620;
    color: var(--ink);
  }

  .venue {
    font-style: italic;
  }

  .venue-tag {
    display: inline-block;
    margin-left: 0.5rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    font-style: normal;
    color: var(--accent-strong);
    background: var(--accent-tint);
    border: 1px solid var(--accent-line);
    border-radius: 4px;
    padding: 0.06rem 0.4rem;
    white-space: nowrap;
    vertical-align: 0.08em;
  }

  /* arXiv preprints stand out from conference tags by color */
  .venue-tag.arxiv {
    color: #9c1c1c;
    background: #fdf0ef;
    border-color: #efd0cd;
  }

  .pub-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.6rem;
  }

  @media (max-width: 700px) {
    .year-group {
      grid-template-columns: 1fr;
      gap: 0.9rem;
    }
  }
</style>
