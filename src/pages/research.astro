---
import { getCollection, render } from "astro:content";
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
import ResearchIcon from "../components/ResearchIcon.astro";

const teams = (await getCollection("research")).sort(
  (a, b) => a.data.order - b.data.order
);

const rendered = await Promise.all(
  teams.map(async (team) => ({
    team,
    Content: (await render(team)).Content,
  }))
);

const pubs = await getCollection("publications");
const recentFor = (id: string) =>
  pubs
    .filter((p) => p.data.area === id)
    .sort((a, b) => b.data.year - a.data.year || a.data.order - b.data.order)
    .slice(0, 3);

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
);

/* one muted accent per topic — used for the top border, icon, and tagline */
const colors: Record<string, string> = {
  "efficient-ai": "#3b5ba5",
  eda: "#96682f",
  arch: "#7d4b8f",
};
---

<Base title="Research">
  <PageHeader kicker="Research" title="Research Areas" />

  <div class="container section">
    <div class="team-grid">
      {
        rendered.map(({ team, Content }, i) => {
          const recent = recentFor(team.id);
          const featured = i === 0;
          return (
            <article
              class:list={["team", "card", { featured }]}
              id={team.id}
              style={`--team-color: ${colors[team.id] ?? "var(--accent)"}`}
            >
              <div class="team-head">
                <ResearchIcon name={team.data.icon} />
                <div>
                  <h2>{team.data.title}</h2>
                  {team.data.tagline && (
                    <p class="tagline">{team.data.tagline}</p>
                  )}
                </div>
              </div>
              <div class="team-body">
                <Content />
              </div>
              {recent.length > 0 && (
                <div class="team-pubs">
                  <p class="pubs-head">Recent papers</p>
                  <ul>
                    {recent.map((pub) => (
                      <li>
                        <svg
                          class="paper-icon"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1.8"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z" />
                          <path d="M14 3v5h5" />
                          <path d="M9 13h6M9 17h4" />
                        </svg>
                        <div class="paper-info">
                          <a href={pub.data.links.paper || "/publications/"}>
                            {pub.data.title}
                          </a>
                          <span class="pub-venue mono">
                            {pub.data.venueShort} {pub.data.year}
                          </span>
                        </div>
                      </li>
                    ))}
                  </ul>
                  <a class="all-link" href="/publications/">
                    All publications →
                  </a>
                </div>
              )}
            </article>
          );
        })
      }
    </div>

    {
      projects.length > 0 && (
        <section class="projects" aria-labelledby="projects-heading">
          <div class="projects-head">
            <h2 id="projects-heading">Projects</h2>
            <p class="projects-sub">Ongoing funded research projects</p>
          </div>
          <ul class="project-list">
            {projects.map((p) => (
              <li class="project card">
                <svg
                  class="project-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M3 7a2 2 0 0 1 2-2h4l2 2.5h8a2 2 0 0 1 2 2V17a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                </svg>
                <div class="project-info">
                  <h3>{p.data.title}</h3>
                  <p class="funder">{p.data.funder}</p>
                </div>
                <span class="period mono">{p.data.period}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </div>
</Base>

<style>
  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .team {
    --tile-color: var(--team-color);
    display: flex;
    flex-direction: column;
    padding: clamp(1.5rem, 3vw, 2rem);
    border-top: 3px solid var(--team-color);
  }

  .team-head {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .team-head h2 {
    font-size: 1.35rem;
  }

  /* ---- Efficient AI: featured, full-width band ---- */
  .team.featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    align-items: start;
    column-gap: clamp(2.25rem, 4vw, 3.5rem);
    padding: clamp(2rem, 3.5vw, 2.75rem);
    border-top-width: 4px;
  }

  .team.featured .team-head {
    grid-column: 1 / -1;
    gap: 1.1rem;
  }

  .team.featured .team-head h2 {
    font-size: 1.7rem;
  }

  .team.featured .tagline {
    font-size: 0.95rem;
  }

  .team.featured .team-body {
    font-size: 0.98rem;
  }

  .team.featured .team-pubs {
    margin-top: 1.5rem;
    padding-top: 0;
    padding-left: clamp(2.25rem, 4vw, 3.5rem);
    border-top: none;
    border-left: 1px solid var(--line);
  }

  .tagline {
    margin-top: 0.35rem;
    font-size: 0.88rem;
    font-weight: 550;
    color: var(--team-color);
  }

  .team-body {
    margin-top: 1rem;
    color: var(--ink-2);
    font-size: 0.94rem;
    line-height: 1.65;
  }

  .team-body :global(p + p) {
    margin-top: 0.7rem;
  }

  /* ---- recent papers, pinned to the card bottom ---- */
  .team-pubs {
    margin-top: auto;
    padding-top: 1.1rem;
    border-top: 1px solid var(--line);
  }

  .team-body + .team-pubs {
    margin-top: 1.25rem;
  }

  .pubs-head {
    font-size: 0.7rem;
    font-weight: 650;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 0.6rem;
  }

  .team-pubs ul {
    display: grid;
    gap: 0.8rem;
  }

  .team-pubs li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.65rem;
    align-items: start;
  }

  .paper-icon {
    width: 17px;
    height: 17px;
    margin-top: 0.15rem;
    color: var(--team-color);
  }

  .paper-info {
    display: grid;
    gap: 0.15rem;
  }

  .team-pubs li a {
    font-size: 0.88rem;
    font-weight: 550;
    line-height: 1.45;
    color: var(--ink);
  }

  .team-pubs li a:hover {
    color: var(--accent-strong);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .pub-venue {
    font-size: 0.72rem;
    color: var(--ink-3);
  }

  .all-link {
    display: inline-block;
    margin-top: 0.85rem;
    font-size: 0.82rem;
    font-weight: 550;
    color: var(--ink-3);
  }

  .all-link:hover {
    color: var(--accent-strong);
  }

  /* ---- funded projects ---- */
  .projects {
    margin-top: clamp(3rem, 6vw, 4.5rem);
  }

  .projects-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .projects-head h2 {
    font-size: clamp(1.35rem, 2.4vw, 1.65rem);
    font-weight: 660;
  }

  .projects-sub {
    font-size: 0.88rem;
    color: var(--ink-3);
  }

  .project-list {
    display: grid;
    gap: 0.85rem;
  }

  .project {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    padding: 1.15rem clamp(1.25rem, 3vw, 1.75rem);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .project:hover {
    border-color: var(--line-strong);
    box-shadow: 0 6px 20px rgb(25 30 40 / 0.05);
  }

  .project-icon {
    flex: none;
    width: 34px;
    height: 34px;
    padding: 0.5rem;
    border-radius: 10px;
    background: var(--accent-tint);
    color: var(--accent-strong);
  }

  .project-info {
    flex: 1;
    min-width: 0;
  }

  .project h3 {
    font-size: 1rem;
    font-weight: 620;
    line-height: 1.45;
  }

  .funder {
    margin-top: 0.3rem;
    font-size: 0.85rem;
    color: var(--ink-2);
  }

  .period {
    flex: none;
    font-size: 0.78rem;
    color: var(--ink-2);
    white-space: nowrap;
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.3rem 0.75rem;
  }

  @media (max-width: 860px) {
    .team-grid {
      grid-template-columns: 1fr;
    }

    .team.featured {
      grid-template-columns: 1fr;
    }

    .team.featured .team-pubs {
      padding-left: 0;
      border-left: none;
      border-top: 1px solid var(--line);
      padding-top: 1.1rem;
    }
  }

  @media (max-width: 560px) {
    .project {
      flex-wrap: wrap;
    }

    .project-info {
      flex-basis: 100%;
      order: 1;
    }

    .period {
      order: 2;
      margin-left: calc(34px + 1.1rem);
    }

    .projects-head {
      flex-direction: column;
      gap: 0.2rem;
    }
  }
</style>
