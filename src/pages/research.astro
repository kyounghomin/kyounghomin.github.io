---
import { getCollection, render } from "astro:content";
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
import ResearchIcon from "../components/ResearchIcon.astro";

const teams = (await getCollection("research")).sort(
  (a, b) => a.data.order - b.data.order
);

const rendered = await Promise.all(
  teams.map(async (team) => ({
    team,
    Content: (await render(team)).Content,
  }))
);
---

<Base title="Research">
  <PageHeader
    kicker="Research"
    title="Research Areas"
    lede="EIC Lab is organized into four teams that share one goal: making intelligent systems dramatically more efficient, from the model down to the transistor."
  />

  <div class="container section">
    <div class="team-grid">
      {
        rendered.map(({ team, Content }) => (
          <article class="team card" id={team.id}>
            <div class="team-head">
              <ResearchIcon name={team.data.icon} />
              <div>
                <h2>{team.data.title}</h2>
                {team.data.tagline && (
                  <p class="tagline">{team.data.tagline}</p>
                )}
              </div>
            </div>
            <div class="team-body">
              <Content />
            </div>
          </article>
        ))
      }
    </div>
  </div>
</Base>

<style>
  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .team {
    padding: clamp(1.5rem, 3vw, 2rem);
  }

  .team-head {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .team-head h2 {
    font-size: 1.45rem;
  }

  .tagline {
    margin-top: 0.35rem;
    font-size: 0.9rem;
    font-weight: 550;
    color: var(--accent-strong);
  }

  .team-body {
    margin-top: 1.1rem;
    color: var(--ink-2);
    font-size: 0.94rem;
    line-height: 1.65;
  }

  .team-body :global(p + p) {
    margin-top: 0.7rem;
  }

  @media (max-width: 860px) {
    .team-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
